# WebSocket URL (use wss:// for production)
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# API base URL
NEXT_PUBLIC_API_URL=http://localhost:3001/api/stats

# Database URL for Neon (required for waitlist)
DATABASE_URL=postgresql://user:password@hostname/dbname?sslmode=require

# Email Configuration for nodemailer (required for waitlist emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Conexion" <your_email@gmail.com>
